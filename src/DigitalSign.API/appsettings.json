{
  "Logging": {
    "LogLevel": {
      "Default": "Information",
      "Microsoft.AspNetCore": "Warning",
      "Microsoft.EntityFrameworkCore": "Warning"
    }
  },
  "AllowedHosts": "*",

  "ConnectionStrings": {
    "DefaultConnection": "Server=YOUR_SERVER;Database=BTDigitalSign;Trusted_Connection=True;TrustServerCertificate=True;"
  },

  "Jwt": {
    "Issuer": "BTDigitalSign",
    "Audience": "BTIntranet",
    "SecretKey": "REPLACE_WITH_STRONG_SECRET_KEY_MIN_32_CHARS",
    "ExpiryMinutes": 480
  },

  "AzureAd": {
    "Instance": "https://login.microsoftonline.com/",
    "TenantId": "YOUR_TENANT_ID",
    "ClientId": "YOUR_CLIENT_ID",
    "ClientSecret": "YOUR_CLIENT_SECRET"
  },

  "Certificate": {
    "StoreLocation": "LocalMachine",
    "StoreName": "My",
    "Thumbprint": "REPLACE_WITH_YOUR_CERT_THUMBPRINT",
    "PfxPath": "",
    "PfxPassword": ""
  },

  "Cors": {
    "AllowedOrigins": [
      "http://localhost:5000",
      "https://localhost:7000",
      "https://YOUR_INTRANET_URL"
    ]
  },

  "Serilog": {
    "MinimumLevel": {
      "Default": "Information",
      "Override": {
        "Microsoft": "Warning",
        "System": "Warning"
      }
    }
  }
}
